APP_NAME=backlog-scoring-service
ENVIRONMENT=dev
AUTH_MODE=disabled
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/scoring
MIGRATION_DATABASE_URL=
DATA_DIR=/data
MAX_UPLOAD_MB=100
MC_DEFAULT_N=10000
MC_MAX_N=50000
SUPABASE_URL=
SUPABASE_JWKS_URL=
JWT_ALLOWED_ALGS=ES256,RS256,HS256
SUPABASE_JWT_SECRET=
CORS_ALLOW_ORIGINS=*
GIT_SHA=
IMAGE_TAG=local
LOG_LEVEL=INFO
